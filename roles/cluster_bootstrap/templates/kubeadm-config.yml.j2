apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
bootstrapTokens:
- groups:
  - system:bootstrappers:kubeadm:default-node-token
  ttl: 24h0m0s
  usages:
  - signing
  - authentication
nodeRegistration:
  kubeletExtraArgs:
    - name: rotate-server-certificates
      value: "true"
patches:
  directory: /etc/kubernetes/kubeadm-patches
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
clusterName: "k8s-{{ foreman_params.cluster_env }}"
controlPlaneEndpoint: "{{ foreman_params.k8s_api_endpoint }}:6443"
networking:
  podSubnet: "{{ k8s_pod_cidr }}"
  serviceSubnet: "{{ k8s_service_cidr }}"
apiServer:
  certSANs:
{% for host in groups['foreman_almalinux10_kubernetescontrolplanenode'] %}
    - "{{ hostvars[host]['ansible_facts']['fqdn'] }}"
    - "{{ hostvars[host]['ansible_facts']['default_ipv4']['address'] }}"
{% endfor %}
    - "{{ foreman_params.k8s_api_endpoint }}"
    - "{{ foreman_params.k8s_api_endpoint_ip }}"
    - "127.0.0.1"
    - "localhost"
  extraArgs:
    - name: encryption-provider-config
      value: /etc/kubernetes/enc/enc.yaml
    - name: audit-policy-file
      value: /etc/kubernetes/audit/policy.yaml
    - name: audit-log-path
      value: /var/log/kubernetes/audit.log
    - name: audit-log-maxage
      value: "30"
    - name: audit-log-maxbackup
      value: "10"
    - name: audit-log-maxsize
      value: "100"
    # OIDC (Headlamp) and the anonymous-auth restriction are configured via the
    # structured AuthenticationConfiguration file mounted below.  A bare
    # --anonymous-auth=false breaks the kubelet's /livez & /readyz probes
    # (401 -> apiserver crash loop), so anonymous is enabled there for health
    # endpoints only.  --authentication-config is mutually exclusive with the
    # --oidc-* flags, so OIDC lives in that file too.
    - name: authentication-config
      value: /etc/kubernetes/apiserver-auth.yaml
    - name: profiling
      value: "false"
    - name: kubelet-certificate-authority
      value: /etc/kubernetes/pki/ca.crt
    - name: service-account-extend-token-expiration
      value: "false"
  extraVolumes:
    - name: enc
      hostPath: /etc/kubernetes/enc
      mountPath: /etc/kubernetes/enc
      readOnly: true
      pathType: DirectoryOrCreate
    - name: audit-policy
      hostPath: /etc/kubernetes/audit
      mountPath: /etc/kubernetes/audit
      readOnly: true
      pathType: DirectoryOrCreate
    - name: audit-logs
      hostPath: /var/log/kubernetes
      mountPath: /var/log/kubernetes
      readOnly: false
      pathType: DirectoryOrCreate
    - name: apiserver-auth
      hostPath: /etc/kubernetes/apiserver-auth.yaml
      mountPath: /etc/kubernetes/apiserver-auth.yaml
      readOnly: true
      pathType: File
controllerManager:
  extraArgs:
    - name: profiling
      value: "false"
scheduler:
  extraArgs:
    - name: profiling
      value: "false"
---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
serverTLSBootstrap: true
rotateCertificates: true
