vrrp_script check_haproxy {
    script "killall -0 haproxy"
    interval 2
    weight 2
}

vrrp_instance VI_1 {
    state {{ foreman_params.keepalived_state }}
    interface {{ ansible_facts['default_ipv4']['interface'] }}
    virtual_router_id 51
    priority {{ foreman_params.keepalived_priority }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass "{{ keepalived_password }}"
    }

    virtual_ipaddress {
        {{ foreman_params.keepalived_vip }}     # your chosen VIP
    }

    track_script {
        check_haproxy
    }
}
