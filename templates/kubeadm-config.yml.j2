apiVersion: kubeadm.k8s.io/v1beta3
kind: InitConfiguration
bootstrapTokens:
- groups:
  - system:bootstrappers:kubeadm:default-node-token
  ttl: 24h0m0s
  usages:
  - signing
  - authentication
nodeRegistration:
  kubeletExtraArgs:
    rotate-server-certificates: "true"
---
apiVersion: kubeadm.k8s.io/v1beta3
kind: ClusterConfiguration
controlPlaneEndpoint: "naxxramas.example.com:6443"
networking:
  podSubnet: "{{ foreman_params.k8s_pod_cidr }}"
  serviceSubnet: "{{ foreman_params.k8s_service_cidr }}"
apiServer:
  certSANs:
  {% for host in groups['foreman_almalinux10_kubernetescontrolplanenode'] %}
    - {{ hostvars[host]['ansible_hostname'] }} 
    - {{ hostvars[host]['ansible_default_ipv4']['address'] }}
  {% endfor %}
    - "172.16.0.29"
    - "127.0.0.1"
    - "localhost"
---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
serverTLSBootstrap: true
rotateCertificates: true
